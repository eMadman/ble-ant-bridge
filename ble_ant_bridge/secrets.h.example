#pragma once
/*
 * secrets.h.example — copy to secrets.h and fill in your ANT+ network key.
 *
 * secrets.h is listed in .gitignore and must never be committed.
 * This example file is safe to commit; it contains no real key material.
 *
 * How to get the ANT+ network key:
 *   1. Register as an ANT+ Adopter at www.thisisant.com (free).
 *   2. Download the ANT+ Network Key from the Adopter portal.
 *   3. Replace the 0x00 placeholders below with the 8 key bytes.
 *
 * Note: this is the PUBLIC NETWORK KEY (network 0), distinct from the
 * ANT LICENSE KEY already defined in nrf_sdm.h (that one is the Garmin
 * eval key baked into the S340 SoftDevice header — not secret).
 *
 * Usage in ble_ant_bridge.ino (Phase 3):
 *   #include "secrets.h"
 *   const uint8_t antNetworkKey[8] = ANT_PLUS_NETWORK_KEY;
 *   SDAntplus.setNetworkKey(ANTPLUS_NETWORK_NUM, antNetworkKey);
 */

#define ANT_PLUS_NETWORK_KEY { 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00 }
